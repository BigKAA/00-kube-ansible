# ============================================================
# Calico Installation — конфигурация установки Calico через Tigera Operator
# Подробнее: https://projectcalico.docs.tigera.io/master/reference/installation/api
# ============================================================

apiVersion: operator.tigera.io/v1
kind: Installation
metadata:
  name: default
spec:
  # Настройка сети Calico
  calicoNetwork:
    # Внимание: ipPools нельзя изменить после установки
    ipPools:
    - name: default
      blockSize: 26
      cidr: {{ pod_network_cidr }}
      encapsulation: {{ encapsulation }}
      natOutgoing: Enabled
      nodeSelector: all()
---
# Настройка Calico API server
apiVersion: operator.tigera.io/v1
kind: APIServer
metadata:
  name: default
spec: {}

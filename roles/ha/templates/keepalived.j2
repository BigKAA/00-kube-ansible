# ============================================================
# Keepalived конфигурация для HA (VRRP)
# ============================================================

# Проверка работоспособности HAProxy
vrrp_script chk_haproxy {
  script "killall -0 haproxy"  # проверка процесса haproxy
  interval 2                   # каждые 2 секунды
  weight 2                     # +2 к приоритету если OK
}

vrrp_instance VI_1 {
  interface {{ ansible_facts.default_ipv4.interface }}  # сетевой интерфейс для мониторинга
{% if inventory_hostname == groups['k8s_masters'][0] %}
  state MASTER                # MASTER на первой ноде
{% else %}
  state BACKUP                # BACKUP на остальных
{% endif %}
  virtual_router_id 51
{% if inventory_hostname == groups['k8s_masters'][0] %}
  priority 101                # приоритет 101 на master
{% else %}
  priority 100                # приоритет 100 на backup
{% endif %}

  virtual_ipaddress {
    {{ ha_cluster_virtual_ip }}/24          # виртуальный IP
  }

  track_script {
    chk_haproxy
  }
}
